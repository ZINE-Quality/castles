function spawnDemonAt(x, y) {
  demons.push({ x, y, hp: DEMON_HP, maxHp: DEMON_HP, shootTimer: DEMON_SHOOT_RATE });
}

function teleportDemon(d) {
  for (let attempt = 0; attempt < 20; attempt++) {
    const angle = Math.random() * Math.PI * 2;
    const dist = 10 + Math.floor(Math.random() * 10);
    const nx = player.x + Math.round(Math.cos(angle) * dist);
    const ny = player.y + Math.round(Math.sin(angle) * dist);
    if (getTile(nx, ny) === 0) {
      d.x = nx; d.y = ny;
      spawnParticles(nx, ny, "#ff6600", 10, 2);
      return;
    }
  }
}

function updateDemons() {
  demonSpawnTimer--;
  if (demonSpawnTimer <= 0) {
    demonSpawnTimer = DEMON_SPAWN_INTERVAL;
    if (demons.length < DEMON_MAX) {
      const angle = Math.random() * Math.PI * 2;
      const dist = 12 + Math.floor(Math.random() * 8);
      const sx = player.x + Math.round(Math.cos(angle) * dist);
      const sy = player.y + Math.round(Math.sin(angle) * dist);
      spawnDemonAt(sx, sy);
      spawnParticles(sx, sy, "#ff4400", 14, 2.5);
    }
  }
  for (let i = demons.length - 1; i >= 0; i--) {
    const d = demons[i];
    const distToPlayer = Math.abs(d.x - player.x) + Math.abs(d.y - player.y);
    if (distToPlayer <= DEMON_FLEE_RADIUS) {
      spawnParticles(d.x, d.y, "#880000", 12, 2);
      teleportDemon(d);
      continue;
    }
    d.shootTimer--;
    if (d.shootTimer <= 0) {
      d.shootTimer = DEMON_SHOOT_RATE;
      const ddx = player.x - d.x, ddy = player.y - d.y;
      const len = Math.sqrt(ddx * ddx + ddy * ddy) || 1;
      fireballs.push({ x: d.x, y: d.y, dx: ddx / len * 0.18, dy: ddy / len * 0.18, dist: 0 });
    }
    if (d.hp <= 0) {
      spawnParticles(d.x, d.y, "#ff4400", 20, 3);
      spawnParticles(d.x, d.y, "#ffd700", 10, 2);
      spawnTextParticle(d.x, d.y - 1, "DEMON SLAIN!", "#ff6600");
      score += 300 + level * 50;
      xp += 8;
      demons.splice(i, 1);
      checkLevelUp();
    }
  }
  for (let i = fireballs.length - 1; i >= 0; i--) {
    const f = fireballs[i];
    f.x += f.dx; f.y += f.dy; f.dist += Math.sqrt(f.dx * f.dx + f.dy * f.dy);
    if (Math.abs(f.x - player.x) < 0.6 && Math.abs(f.y - player.y) < 0.6 && player.invincible <= 0) {
      player.hp -= 12;
      player.invincible = 30;
      shakeTimer = 12;
      spawnParticles(player.x, player.y, "#ff4400", 8, 1.5);
      fireballs.splice(i, 1);
      continue;
    }
    if (f.dist > 25) fireballs.splice(i, 1);
  }
}

function updateProjectiles() {
  for (let i = projectiles.length - 1; i >= 0; i--) {
    const p = projectiles[i];
    p.x += p.dx; p.y += p.dy; p.dist++;
    let hit = false;
    for (let j = enemies.length - 1; j >= 0; j--) {
      if (enemies[j].x === Math.round(p.x) && enemies[j].y === Math.round(p.y)) {
        enemies[j].curHp--;
        if (enemies[j].curHp <= 0) {
          spawnParticles(enemies[j].x, enemies[j].y, "#ff8800", 6);
          spawnTextParticle(enemies[j].x, enemies[j].y, `+${enemies[j].xp}XP`);
          xp += enemies[j].xp; score += enemies[j].xp * 10;
          enemies.splice(j, 1);
          checkLevelUp();
        }
        hit = true; break;
      }
    }
    if (!hit) {
      for (let j = bosses.length - 1; j >= 0; j--) {
        if (Math.abs(p.x - bosses[j].x) <= 1 && Math.abs(p.y - bosses[j].y) <= 1) {
          bosses[j].hp -= 5; hit = true;
          spawnParticles(bosses[j].x, bosses[j].y, "#ff4444", 4, 1);
          spawnTextParticle(bosses[j].x, bosses[j].y - 1, "-5", "#ff4444");
          break;
        }
      }
    }
    if (!hit) {
      for (let j = demons.length - 1; j >= 0; j--) {
        if (Math.abs(p.x - demons[j].x) <= 1 && Math.abs(p.y - demons[j].y) <= 1) {
          demons[j].hp -= 5; hit = true;
          spawnParticles(demons[j].x, demons[j].y, "#88ffff", 5, 1.5);
          spawnTextParticle(demons[j].x, demons[j].y - 1, "-5", "#88ffff");
          break;
        }
      }
    }
    if (hit || p.dist > 30) projectiles.splice(i, 1);
  }
}

function checkLevelUp() {
  if (level >= 15) return;
  if (xp >= XP_PER_LEVEL * level) {
    level++;
    player.maxHp = Math.min(player.maxHp + 3, 150);
    player.hp = Math.min(player.hp + 5, player.maxHp);
    if (level === 15) {
      showToast("🏆 MAX LEVEL! HP 150");
    } else {
      showToast(`⬆ LEVEL ${level}! +5 HP`);
    }
  }
}

function showToast(msg) {
  const t = document.getElementById("levelUpToast");
  t.textContent = msg;
  t.style.opacity = "1";
  setTimeout(() => { t.style.opacity = "0"; }, 2000);
}

function updateBosses() {
  if (bossTimer > 0) {
    bossTimer--;
    if (bossTimer === 180) showBossAlert();
  } else {
    const bX = player.x + (Math.random() > 0.5 ? 18 : -18);
    const bY = player.y + (Math.random() > 0.5 ? 18 : -18);
    bosses.push({ x: bX, y: bY, hp: 40 + level * 5, maxHp: 40 + level * 5, timer: 0, facingRight: false });
    bossTimer = BOSS_INTERVAL;
  }
  for (let i = bosses.length - 1; i >= 0; i--) {
    const b = bosses[i];
    b.timer--;
    if (b.timer <= 0) {
      b.timer = Math.max(15, 35 - level * 2);
      const dx = Math.sign(player.x - b.x), dy = Math.sign(player.y - b.y);
      if (dx !== 0) b.facingRight = dx > 0;
      let moved = false;
      for (const [bdx, bdy] of [[dx, dy],[dx, 0],[0, dy]]) {
        const nx = b.x + bdx, ny = b.y + bdy;
        const nt = getTile(nx, ny);
        if (nt === "door") continue;
        b.x = nx; b.y = ny; moved = true; break;
      }
      if (getTile(b.x, b.y) === "🍄") {
        b.hp -= 15;
        setTile(b.x, b.y, 0);
        spawnParticles(b.x, b.y, "#aa44ff", 8);
        spawnTextParticle(b.x, b.y - 1, "-15", "#aa44ff");
      }
      for (let ox = -1; ox <= 1; ox++)
        for (let oy = -1; oy <= 1; oy++) {
          const t = getTile(b.x + ox, b.y + oy);
          if (t !== 0 && t !== "lava") setTile(b.x + ox, b.y + oy, 0);
        }
    }
    if (Math.abs(b.x - player.x) <= 1 && Math.abs(b.y - player.y) <= 1 && player.invincible <= 0) {
      player.hp -= 15;
      player.invincible = 40;
      shakeTimer = 20;
      player.x -= Math.sign(player.x - b.x) * 2;
      player.y -= Math.sign(player.y - b.y) * 2;
    }
    if (b.hp <= 0) {
      spawnParticles(b.x, b.y, "#ffd700", 30, 3);
      spawnTextParticle(b.x, b.y - 2, "BOSS DEFEATED!", "#ffd700");
      score += 500 + level * 100;
      xp += 25;
      bosses.splice(i, 1);
      checkLevelUp();
      showToast("🏆 BOSS SLAIN! +500 SCORE");
    }
  }
}

function showBossAlert() {
  const el = document.getElementById("bossAlert");
  el.style.opacity = "1";
  setTimeout(() => { el.style.opacity = "0"; }, 3000);
}

function showRainbowAlert() {
  const el = document.getElementById("rainbowAlert");
  el.style.opacity = "1";
  setTimeout(() => { el.style.opacity = "0"; }, 2500);
}

function updateDayNight() {
  dayTime = (dayTime + 1 / DAY_CYCLE) % 1;
}

function getDayNightOverlay() {
  const t = dayTime;
  let darkness;
  if (t < 0.4)      darkness = 0;
  else if (t < 0.5) darkness = (t - 0.4) / 0.1 * 0.75;
  else if (t < 0.9) darkness = 0.75;
  else              darkness = (1 - t) / 0.1 * 0.75;
  return darkness;
}

function getDayLabel() {
  const t = dayTime;
  if (t < 0.4)      return { text: "DAY",   color: "#ffdd44" };
  if (t < 0.5)      return { text: "DUSK",  color: "#ff8844" };
  if (t < 0.9)      return { text: "NIGHT", color: "#8888ff" };
  return             { text: "DAWN",  color: "#ffaa44" };
}

function drawDayBar() {
  const bc = document.getElementById("dayBar");
  const bx = bc.getContext("2d");
  const W = bc.width, H = bc.height;
  bx.clearRect(0, 0, W, H);
  const trackY = H / 2, trackH = 6, trackR = 3;
  const trackX = 14, trackW = W - 28;
  bx.fillStyle = "#0a0a1a";
  bx.beginPath(); bx.roundRect(trackX, trackY - trackH/2, trackW, trackH, trackR); bx.fill();
  const grad = bx.createLinearGradient(trackX, 0, trackX + trackW, 0);
  grad.addColorStop(0, "#ffdd44"); grad.addColorStop(0.4, "#ffcc00");
  grad.addColorStop(0.45, "#ff6622"); grad.addColorStop(0.5, "#220066");
  grad.addColorStop(0.9, "#110044"); grad.addColorStop(1, "#ff9944");
  bx.fillStyle = grad;
  bx.beginPath(); bx.roundRect(trackX, trackY - trackH/2, trackW, trackH, trackR); bx.fill();
  const indicX = trackX + dayTime * trackW;
  const isNight = dayTime > 0.45 && dayTime < 0.95;
  const glowColor = isNight ? "#8888ff" : "#ffdd44";
  bx.shadowColor = glowColor; bx.shadowBlur = 8;
  bx.beginPath(); bx.arc(indicX, trackY, 7, 0, Math.PI * 2);
  bx.fillStyle = isNight ? "#222255" : "#000"; bx.fill();
  bx.strokeStyle = glowColor; bx.lineWidth = 2; bx.stroke();
  bx.shadowBlur = 0;
  bx.font = "9px serif"; bx.textAlign = "center"; bx.textBaseline = "middle";
  bx.fillText(isNight ? "🌙" : "☀", indicX, trackY);
  for (const tick of [0.4, 0.5, 0.9]) {
    const tx = trackX + tick * trackW;
    bx.strokeStyle = "#ffffff22"; bx.lineWidth = 1;
    bx.beginPath(); bx.moveTo(tx, trackY - trackH/2 - 2); bx.lineTo(tx, trackY + trackH/2 + 2); bx.stroke();
  }
  bx.font = "10px serif"; bx.globalAlpha = 0.7;
  bx.fillText("☀", trackX - 8, trackY); bx.fillText("🌙", trackX + trackW + 8, trackY);
  bx.globalAlpha = 1;
}

function drawBossHealth(b) {
  const barW = TILE * 3, barH = 10;
  const px = b.x * TILE - camera.x + TILE / 2 - barW / 2;
  const py = (b.y - 1) * TILE - camera.y - 20;
  ctx.fillStyle = "#000"; ctx.fillRect(px - 1, py - 1, barW + 2, barH + 2);
  const pct = Math.max(0, b.hp / b.maxHp);
  ctx.fillStyle = pct > 0.5 ? "#00ff44" : pct > 0.25 ? "#ffaa00" : "#ff2200";
  ctx.fillRect(px, py, barW * pct, barH);
  ctx.strokeStyle = "#ffffff44"; ctx.lineWidth = 1; ctx.strokeRect(px, py, barW, barH);
  ctx.font = "10px 'Share Tech Mono'"; ctx.textAlign = "center"; ctx.fillStyle = "#fff";
  ctx.fillText(`BOSS ${Math.ceil(b.hp)}/${b.maxHp}`, px + barW / 2, py - 4);
}

function draw() {
  let shakeX = 0, shakeY = 0;
  if (shakeTimer > 0) {
    shakeX = (Math.random() - 0.5) * 8;
    shakeY = (Math.random() - 0.5) * 8;
    shakeTimer--;
  }
  ctx.fillStyle = "#000";
  ctx.fillRect(0, 0, canvas.width, canvas.height);

  const playerScreenX = player.x * TILE - camera.x;
  const playerScreenY = player.y * TILE - camera.y;
  const centerX = canvas.width / 2, centerY = canvas.height / 2;
  if (playerScreenX < centerX - DEAD_ZONE) cameraTarget.x = player.x * TILE - (centerX - DEAD_ZONE);
  if (playerScreenX > centerX + DEAD_ZONE) cameraTarget.x = player.x * TILE - (centerX + DEAD_ZONE);
  if (playerScreenY < centerY - DEAD_ZONE) cameraTarget.y = player.y * TILE - (centerY - DEAD_ZONE);
  if (playerScreenY > centerY + DEAD_ZONE) cameraTarget.y = player.y * TILE - (centerY + DEAD_ZONE);
  camera.x += (cameraTarget.x - camera.x) * CAM_EASE + shakeX;
  camera.y += (cameraTarget.y - camera.y) * CAM_EASE + shakeY;

  const sx = Math.floor(camera.x / TILE) - 1, sy = Math.floor(camera.y / TILE) - 1;
  const ex = sx + Math.ceil(canvas.width / TILE) + 2, ey = sy + Math.ceil(canvas.height / TILE) + 2;
  const darkness = getDayNightOverlay();

  ctx.strokeStyle = darkness > 0.5 ? "#0a1a0a" : "#111"; ctx.lineWidth = 0.5;
  for (let gx = sx; gx < ex; gx++) {
    const px = gx * TILE - camera.x;
    ctx.beginPath(); ctx.moveTo(px, 0); ctx.lineTo(px, canvas.height); ctx.stroke();
  }
  for (let gy = sy; gy < ey; gy++) {
    const py = gy * TILE - camera.y;
    ctx.beginPath(); ctx.moveTo(0, py); ctx.lineTo(canvas.width, py); ctx.stroke();
  }

  ctx.font = TILE + "px serif"; ctx.textAlign = "center"; ctx.textBaseline = "middle";
  for (let y = sy; y < ey; y++) {
    for (let x = sx; x < ex; x++) {
      const t = getTile(x, y);
      const px = x * TILE - camera.x + TILE / 2, py = y * TILE - camera.y + TILE / 2;
      if (t === "lava") {
        const flicker = 0.8 + 0.2 * Math.sin(frameCount * 0.1 + x + y);
        ctx.fillStyle = `rgba(255,${Math.floor(60 * flicker)},0,1)`;
        ctx.fillRect(x * TILE - camera.x, y * TILE - camera.y, TILE, TILE);
        const grad = ctx.createRadialGradient(px, py, 0, px, py, TILE);
        grad.addColorStop(0, `rgba(255,100,0,${0.3 * flicker})`);
        grad.addColorStop(1, "transparent");
        ctx.fillStyle = grad;
        ctx.fillRect(x * TILE - camera.x - TILE, y * TILE - camera.y - TILE, TILE * 3, TILE * 3);
      } else if (t === "iron") {
        ctx.fillStyle = "#334"; ctx.fillRect(x * TILE - camera.x, y * TILE - camera.y, TILE, TILE);
        ctx.strokeStyle = "#556"; ctx.lineWidth = 1;
        ctx.strokeRect(x * TILE - camera.x + 2, y * TILE - camera.y + 2, TILE - 4, TILE - 4);
      } else if (t === "door") {
        ctx.fillStyle = "#5a3010"; ctx.fillRect(x * TILE - camera.x, y * TILE - camera.y, TILE, TILE);
        ctx.fillStyle = "#7a4820";
        const bx2 = x * TILE - camera.x, by2 = y * TILE - camera.y;
        ctx.fillRect(bx2 + 4, by2 + 2, (TILE-8)/2 - 1, TILE - 4);
        ctx.fillRect(bx2 + 4 + (TILE-8)/2 + 2, by2 + 2, (TILE-8)/2 - 1, TILE - 4);
        ctx.fillStyle = "#ffd700";
        ctx.beginPath(); ctx.arc(bx2 + TILE * 0.65, by2 + TILE * 0.55, 2.5, 0, Math.PI * 2); ctx.fill();
        ctx.strokeStyle = "#3a1a00"; ctx.lineWidth = 2;
        ctx.strokeRect(bx2 + 2, by2 + 2, TILE - 4, TILE - 4);
      } else if (typeof t === "string") {
        ctx.fillText(t, px, py);
      }
    }
  }

  // Rage pickups
  for (const rp of ragePickups) {
    const rpx = rp.x * TILE - camera.x, rpy = rp.y * TILE - camera.y;
    const expiring = rp.ttl < 3 * 60;
    const pulse = expiring ? (Math.floor(frameCount / 8) % 2 === 0 ? 0.9 : 0.1) : 0.7 + 0.3 * Math.sin(frameCount * 0.12);
    ctx.globalAlpha = pulse; ctx.shadowColor = "#ff4400"; ctx.shadowBlur = 14 * pulse;
    if (rageIconImg.complete && rageIconImg.naturalWidth > 0) ctx.drawImage(rageIconImg, rpx + 2, rpy + 2, TILE - 4, TILE - 4);
    else { ctx.font = (TILE * 0.8) + "px serif"; ctx.fillText("😡", rpx + TILE/2, rpy + TILE/2); }
    ctx.shadowBlur = 0; ctx.globalAlpha = 1;
  }

  // Purple pickups
  for (const pp of purplePickups) {
    const ppx = pp.x * TILE - camera.x, ppy = pp.y * TILE - camera.y;
    const expiring = pp.ttl < 3 * 60;
    const pulse = expiring ? (Math.floor(frameCount / 8) % 2 === 0 ? 0.9 : 0.1) : 0.7 + 0.3 * Math.sin(frameCount * 0.15);
    ctx.globalAlpha = pulse; ctx.shadowColor = "#cc44ff"; ctx.shadowBlur = 14 * pulse;
    if (purpleIconImg.complete && purpleIconImg.naturalWidth > 0) ctx.drawImage(purpleIconImg, ppx + 2, ppy + 2, TILE - 4, TILE - 4);
    else { ctx.font = (TILE * 0.8) + "px serif"; ctx.fillText("⚡", ppx + TILE/2, ppy + TILE/2); }
    ctx.shadowBlur = 0; ctx.globalAlpha = 1;
  }

  // Wrench pickups
  for (const wp of wrenchPickups) {
    const wpx = wp.x * TILE - camera.x, wpy = wp.y * TILE - camera.y;
    const expiring = wp.ttl < 3 * 60;
    const pulse = expiring ? (Math.floor(frameCount / 8) % 2 === 0 ? 0.9 : 0.1) : 0.7 + 0.3 * Math.sin(frameCount * 0.13);
    ctx.globalAlpha = pulse; ctx.shadowColor = "#44ff88"; ctx.shadowBlur = 14 * pulse;
    if (wrenchIconImg.complete && wrenchIconImg.naturalWidth > 0) ctx.drawImage(wrenchIconImg, wpx + 2, wpy + 2, TILE - 4, TILE - 4);
    else { ctx.font = (TILE * 0.8) + "px serif"; ctx.fillText("🔧", wpx + TILE/2, wpy + TILE/2); }
    ctx.shadowBlur = 0; ctx.globalAlpha = 1;
  }

  // Rainbow pickups
  for (const rp of rainbowPickups) {
    const rpx = rp.x * TILE - camera.x, rpy = rp.y * TILE - camera.y;
    const expiring = rp.ttl < 3 * 60;
    const pulse = expiring ? (Math.floor(frameCount / 8) % 2 === 0 ? 0.9 : 0.1) : 0.7 + 0.3 * Math.sin(frameCount * 0.14);
    const hue = (frameCount * 4) % 360;
    ctx.globalAlpha = pulse;
    ctx.shadowColor = `hsl(${hue},100%,60%)`; ctx.shadowBlur = 16 * pulse;
    if (rainbowIconImg.complete && rainbowIconImg.naturalWidth > 0) ctx.drawImage(rainbowIconImg, rpx + 2, rpy + 2, TILE - 4, TILE - 4);
    else { ctx.font = (TILE * 0.8) + "px serif"; ctx.textAlign = "center"; ctx.textBaseline = "middle"; ctx.fillText("🌈", rpx + TILE/2, rpy + TILE/2); }
    ctx.shadowBlur = 0; ctx.globalAlpha = 1;
  }

  // Enemies
  ctx.font = TILE * 0.8 + "px serif";
  for (const e of enemies) {
    const px = e.x * TILE + TILE / 2 - camera.x, py = e.y * TILE + TILE / 2 - camera.y;
    if (e.night && darkness > 0.3) { ctx.shadowColor = "#ff0000"; ctx.shadowBlur = 8; }
    ctx.fillText(e.emoji, px, py);
    ctx.shadowBlur = 0;
  }

  // Projectiles
  ctx.font = TILE * 0.7 + "px serif";
  for (const p of projectiles) {
    ctx.shadowColor = "#88ffff"; ctx.shadowBlur = 10;
    ctx.fillText("⚡", p.x * TILE + TILE / 2 - camera.x, p.y * TILE + TILE / 2 - camera.y);
  }
  ctx.shadowBlur = 0;

  // Fireballs
  for (const f of fireballs) {
    const fpx = f.x * TILE + TILE / 2 - camera.x;
    const fpy = f.y * TILE + TILE / 2 - camera.y;
    const pulse = 0.85 + 0.15 * Math.sin(frameCount * 0.3);
    ctx.globalAlpha = pulse;
    ctx.shadowColor = "#ff4400"; ctx.shadowBlur = 28;
    if (fireballImg.complete && fireballImg.naturalWidth > 0) {
      const fsz = TILE * 3;
      ctx.drawImage(fireballImg, fpx - fsz/2, fpy - fsz/2, fsz, fsz);
    } else {
      ctx.font = (TILE * 2.8) + "px serif";
      ctx.textAlign = "center"; ctx.textBaseline = "middle";
      ctx.fillText("🔥", fpx, fpy);
    }
    ctx.shadowBlur = 0; ctx.globalAlpha = 1;
  }

  // Demons
  for (const d of demons) {
    const dSize = TILE * 4;
    const dpx = d.x * TILE + TILE/2 - camera.x - dSize/2;
    const dpy = d.y * TILE + TILE/2 - camera.y - dSize/2;
    const bob = Math.sin(frameCount * 0.07 + d.x) * 5;
    ctx.shadowColor = "#ff2200"; ctx.shadowBlur = 16 + 8 * Math.sin(frameCount * 0.1);
    if (demonImg.complete && demonImg.naturalWidth > 0) {
      ctx.drawImage(demonImg, dpx, dpy + bob, dSize, dSize);
    } else {
      ctx.font = dSize + "px serif";
      ctx.textAlign = "center"; ctx.textBaseline = "middle";
      ctx.fillText("👿", d.x * TILE + TILE/2 - camera.x, d.y * TILE + TILE/2 - camera.y + bob);
    }
    ctx.shadowBlur = 0;
    const barW = TILE * 3, barH = 8;
    const bpx = d.x * TILE - camera.x + TILE/2 - barW/2;
    const bpy = d.y * TILE - camera.y - dSize/2 - 18 + bob;
    ctx.fillStyle = "#000"; ctx.fillRect(bpx - 1, bpy - 1, barW + 2, barH + 2);
    const pct = Math.max(0, d.hp / d.maxHp);
    ctx.fillStyle = pct > 0.5 ? "#ff4400" : pct > 0.25 ? "#ff8800" : "#ffff00";
    ctx.fillRect(bpx, bpy, barW * pct, barH);
    ctx.strokeStyle = "#ffffff44"; ctx.lineWidth = 1;
    ctx.strokeRect(bpx, bpy, barW, barH);
    ctx.font = "9px 'Share Tech Mono'"; ctx.textAlign = "center"; ctx.fillStyle = "#fff";
    ctx.fillText(`DEMON ${Math.ceil(d.hp)}/${d.maxHp}`, bpx + barW/2, bpy - 4);
  }

  // Bosses — flip horizontally when moving right
  for (const b of bosses) {
    const bossSize = TILE * 3;
    const bx3 = (b.x - 1) * TILE - camera.x;
    const by3 = (b.y - 1) * TILE - camera.y;
    ctx.save();
    if (b.facingRight) {
      ctx.translate(bx3 + bossSize / 2, by3 + bossSize / 2);
      ctx.scale(-1, 1);
      ctx.translate(-(bx3 + bossSize / 2), -(by3 + bossSize / 2));
    }
    if (bossImg.complete && bossImg.naturalWidth > 0) {
      ctx.drawImage(bossImg, bx3, by3, bossSize, bossSize);
    } else {
      ctx.font = bossSize + "px serif";
      ctx.textAlign = "center"; ctx.textBaseline = "middle";
      ctx.fillText("👹", b.x * TILE + TILE / 2 - camera.x, b.y * TILE + TILE / 2 - camera.y);
    }
    ctx.restore();
    drawBossHealth(b);
  }

  // Player
  const rageEl = document.getElementById("rageGifEl");
  const purpleEl = document.getElementById("purpleGifEl");
  if (purpleTimer > 0) {
    const vAlpha = 0.1 + 0.07 * Math.sin(frameCount * 0.25);
    ctx.fillStyle = `rgba(100,0,200,${vAlpha})`;
    ctx.fillRect(0, 0, canvas.width, canvas.height);
    if (frameCount % 3 === 0) {
      ctx.strokeStyle = `rgba(180,80,255,${0.3 + 0.2 * Math.random()})`;
      ctx.lineWidth = 1.5; ctx.beginPath();
      ctx.moveTo(player.x * TILE + TILE/2 - camera.x, player.y * TILE + TILE/2 - camera.y);
      ctx.lineTo(Math.random() * canvas.width, Math.random() * canvas.height);
      ctx.stroke();
    }
    const purpleSize = TILE * 2;
    const ppx2 = player.x * TILE + TILE/2 - camera.x - purpleSize/2;
    const ppy2 = player.y * TILE + TILE/2 - camera.y - purpleSize/2;
    purpleEl.style.display = "block";
    purpleEl.style.left = Math.round(ppx2) + "px";
    purpleEl.style.top = Math.round(ppy2) + "px";
    purpleEl.style.width = purpleSize + "px";
    purpleEl.style.height = purpleSize + "px";
    purpleEl.style.filter = `drop-shadow(0 0 ${8 + 5 * Math.sin(frameCount * 0.2)}px #cc44ff)`;
  } else {
    purpleEl.style.display = "none";
  }
  if (rageTimer > 0) {
    const rageSize = TILE * 2;
    const rpx = player.x * TILE + TILE/2 - camera.x - rageSize/2;
    const rpy = player.y * TILE + TILE/2 - camera.y - rageSize/2;
    const vAlpha = 0.12 + 0.08 * Math.sin(frameCount * 0.2);
    ctx.fillStyle = `rgba(255,30,0,${vAlpha})`;
    ctx.fillRect(0, 0, canvas.width, canvas.height);
    rageEl.style.display = "block";
    rageEl.style.left = Math.round(rpx) + "px";
    rageEl.style.top = Math.round(rpy) + "px";
    rageEl.style.width = rageSize + "px";
    rageEl.style.height = rageSize + "px";
    rageEl.style.filter = `drop-shadow(0 0 ${10 + 6 * Math.sin(frameCount * 0.15)}px #ff2200)`;
  } else {
    rageEl.style.display = "none";
    if (purpleTimer <= 0) {
      ctx.font = TILE + "px serif";
      ctx.textAlign = "center"; ctx.textBaseline = "middle";
      if (player.invincible > 0 && Math.floor(frameCount / 3) % 2 === 0) ctx.globalAlpha = 0.4;
      ctx.fillText(player.hp > 0 ? "🤖" : "☠️", player.x * TILE + TILE/2 - camera.x, player.y * TILE + TILE/2 - camera.y);
      ctx.globalAlpha = 1;
    }
  }

  drawParticles();

  // Rainbow flicker overlay
  if (rainbowFlicker > 0) {
    const progress = rainbowFlicker / RAINBOW_FLICKER_DURATION;
    const hue = (frameCount * 18) % 360;
    ctx.fillStyle = `hsla(${hue},100%,55%,${0.28 * progress})`;
    ctx.fillRect(0, 0, canvas.width, canvas.height);
    ctx.fillStyle = `hsla(${(hue + 120) % 360},100%,55%,${0.15 * progress})`;
    ctx.fillRect(0, 0, canvas.width, canvas.height);
  }

  // Day/Night overlay
  if (darkness > 0) {
    ctx.fillStyle = `rgba(0,5,30,${darkness})`;
    ctx.fillRect(0, 0, canvas.width, canvas.height);
    if (darkness > 0.4) {
      for (let s = 0; s < 80; s++) {
        const sx2 = ((s * 173 + frameCount * 0.5) % canvas.width);
        const sy2 = ((s * 97) % (canvas.height * 0.6));
        const twinkle = 0.5 + 0.5 * Math.sin(frameCount * 0.05 + s);
        ctx.globalAlpha = twinkle * (darkness - 0.4) * 2;
        ctx.fillStyle = "#ffffff";
        ctx.fillRect(sx2, sy2, 1.5, 1.5);
      }
      ctx.globalAlpha = 1;
    }
  }

  // HUD
  const hpPct = Math.max(0, player.hp / player.maxHp * 100);
  document.getElementById("hpFill").style.width = hpPct + "%";
  document.getElementById("hpVal").textContent = Math.ceil(player.hp);
  document.getElementById("scoreVal").textContent = score;
  document.getElementById("levelVal").textContent = level;
  document.getElementById("bestVal").textContent = getBestScore();
  const sec = Math.ceil(bossTimer / 60);
  document.getElementById("bossTimerVal").textContent = `${Math.floor(sec / 60)}:${(sec % 60).toString().padStart(2, "0")}`;
  const dl = getDayLabel();
  document.getElementById("dayPhaseLbl").textContent = dl.text;
  document.getElementById("dayPhaseLbl").style.color = dl.color;
  drawDayBar();

  // Rage HUD
  const rageSection = document.getElementById("rageSection");
  if (rageStored || rageTimer > 0) {
    rageSection.style.display = "flex";
    const rageFill = document.getElementById("rageFill");
    const rageLabel = document.getElementById("rageLabel");
    if (rageTimer > 0) {
      rageFill.style.width = (rageTimer / RAGE_DURATION * 100) + "%";
      rageFill.style.background = "linear-gradient(90deg,#ff2200,#ff8800)";
      rageLabel.textContent = Math.ceil(rageTimer / 60) + "s";
      rageLabel.style.color = "#ff4400";
    } else {
      rageFill.style.width = "100%";
      rageFill.style.background = "linear-gradient(90deg,#ff6600,#ffcc00)";
      rageLabel.textContent = "READY";
      rageLabel.style.color = "#ffcc00";
    }
  } else {
    rageSection.style.display = "none";
  }

  // Purple HUD
  const purpleSection = document.getElementById("purpleSection");
  if (purpleStored || purpleTimer > 0) {
    purpleSection.style.display = "flex";
    const purpleFill = document.getElementById("purpleFill");
    const purpleLabel = document.getElementById("purpleLabel");
    if (purpleTimer > 0) {
      purpleFill.style.width = (purpleTimer / PURPLE_ELEC_DURATION * 100) + "%";
      purpleLabel.textContent = Math.ceil(purpleTimer / 60) + "s";
      purpleLabel.style.color = "#cc44ff";
    } else {
      purpleFill.style.width = "100%";
      purpleLabel.textContent = "READY";
      purpleLabel.style.color = "#dd88ff";
    }
  } else {
    purpleSection.style.display = "none";
  }

  if (paused) {
    document.getElementById("rageGifEl").style.display = "none";
    document.getElementById("purpleGifEl").style.display = "none";
    drawPauseOverlay();
  }

  if (player.hp <= 0) {
    document.getElementById("rageGifEl").style.display = "none";
    document.getElementById("purpleGifEl").style.display = "none";
    if (!_deadPlayed) {
      _deadPlayed = true;
      document.getElementById("bgMusic").pause();
      const deadSound = document.getElementById("deadSound");
      deadSound.volume = 0.8;
      deadSound.currentTime = 0;
      deadSound.play().catch(() => {});
      const best = getBestScore();
      if (score > best) saveBestScore(score);
    }
    const best = getBestScore();
    document.getElementById("finalScore").textContent =
      `Score: ${score} | Level: ${level}${score >= best && score > 0 ? " | 🏆 NEW BEST!" : " | Best: " + best}`;
    document.getElementById("gameOverScreen").style.display = "flex";
  }
}

function updateCooldowns() {
  for (const k in actionCooldown) {
    actionCooldown[k]--;
    if (actionCooldown[k] <= 0) delete actionCooldown[k];
  }
  if (player.invincible > 0) player.invincible--;
}

function togglePause() {
  paused = !paused;
  const btn = document.getElementById("pauseBtn");
  const music = document.getElementById("bgMusic");
  if (paused) {
    btn.textContent = "▶ RESUME";
    btn.style.color = "#ffd700";
    btn.style.borderColor = "#ffd700";
    music.pause();
  } else {
    btn.textContent = "⏸ PAUSE";
    btn.style.color = "#88ff88";
    btn.style.borderColor = "#1a4a1a";
    music.play().catch(() => {});
    loop();
  }
}

function drawPauseOverlay() {
  ctx.fillStyle = "rgba(0,0,0,0.55)";
  ctx.fillRect(0, 0, canvas.width, canvas.height);
  ctx.textAlign = "center"; ctx.textBaseline = "middle";
  ctx.font = "bold 28px 'Press Start 2P', monospace";
  ctx.fillStyle = "#ffd700";
  ctx.shadowColor = "#ffd700"; ctx.shadowBlur = 20;
  ctx.fillText("PAUSED", canvas.width / 2, canvas.height / 2 - 16);
  ctx.shadowBlur = 0;
  ctx.font = "12px 'Share Tech Mono', monospace";
  ctx.fillStyle = "#448844";
  ctx.fillText("click RESUME to continue", canvas.width / 2, canvas.height / 2 + 22);
}

function loop() {
  if (!gameStarted || paused) return;
  frameCount++;
  handleMovement();
  handleActions();
  updateEnemies();
  updateBosses();
  updateProjectiles();
  updateRage();
  updatePurple();
  updateWrench();
  updateRainbow();
  updateDemons();
  updateParticles();
  updateDayNight();
  updateCooldowns();
  draw();
  requestAnimationFrame(loop);
}

function startGame() {
  _deadPlayed = false;
  document.getElementById("titleScreen").style.display = "none";
  for (let i = 0; i < 15; i++) spawnStructure("room");
  for (let i = 0; i < 10; i++) spawnStructure("cross");
  for (let x = -12; x <= 12; x++)
    for (let y = -12; y <= 12; y++) getTile(x, y);
  const music = document.getElementById("bgMusic");
  music.volume = 0.3;
  music.play().catch(() => {});
  gameStarted = true;
  loop();
}

document.getElementById("startBtn").onclick = startGame;
</script>
