<!DOCTYPE html>
<!-- 
  🎮 BUILDER BROS - BOSS EDITION
  ================================
  This is a video game made entirely in a web browser!
  It uses three languages:
    - HTML  = the skeleton (buttons, screens, text boxes)
    - CSS   = the makeup (colors, fonts, animations)
    - JavaScript = the brain (all the actual game logic!)
  
  Read the comments (lines starting with // or between these arrow symbols)
  to learn how it all works!
-->
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Builder Bros. - Boss Edition</title>

<style>
  /*
    CSS STYLES
    ===========
    CSS is like a costume designer for your game.
    Each block says "find this thing and make it look like THIS."
    For example: #startBtn means "find the element with id="startBtn""
    and then we tell it what color, size, shape etc. to be!
  */

  /* Load two cool retro fonts from Google's free font library */
  @import url('https://fonts.googleapis.com/css2?family=Press+Start+2P&family=Share+Tech+Mono&display=swap');

  /* 
    Make EVERY element use "border-box" sizing.
    This means padding is counted INSIDE the width, not added on top.
    Also wipe out all default spacing browsers add automatically.
  */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  /* 
    :root is like a color dictionary for our game.
    We name colors so we can say "var(--green)" anywhere instead of "#88ff88".
    Change one line here and the whole color scheme updates everywhere!
  */
  :root {
    --green: #88ff88;           /* bright lime green - our main color */
    --red: #ff4444;             /* danger red */
    --gold: #ffd700;            /* shiny gold for scores and level ups */
    --dark: #000;               /* plain black */
    --panel: rgba(0,20,0,0.85); /* dark green semi-transparent panel */
  }

  /* Make the whole page black and hide scrollbars (it's a game, not a website!) */
  html, body {
    width: 100%; height: 100%;
    background: #000;
    overflow: hidden;             /* no scrollbars! */
    font-family: 'Share Tech Mono', monospace;
    color: var(--green);          /* default text is green */
  }

  canvas { display: block; } /* the game canvas sits as its own block */

  /* 
    THE HUD (Heads-Up Display)
    The strip at the TOP showing HP, score, boss timer etc.
    position:fixed means it stays in place even if the world scrolls.
  */
  #hud {
    position: fixed; top: 0; left: 0; right: 0; /* glued to the top */
    display: flex; align-items: center; gap: 16px; /* items in a row */
    padding: 8px 16px;
    background: var(--panel);
    border-bottom: 1px solid #1a4a1a; /* thin dark green line under it */
    z-index: 900;          /* z-index = layering. 900 = in front of the game */
    font-size: 13px;
    backdrop-filter: blur(4px); /* frosted glass effect! blurs the game behind it */
  }
  #hud .section { display: flex; align-items: center; gap: 8px; }
  #hud .sep { color: #1a4a1a; font-size: 18px; } /* the | dividers between sections */

  /* HP bar: a colored rectangle that shrinks as you take damage */
  #hpBar { width: 120px; height: 12px; background: #111; border: 1px solid #333; border-radius: 2px; overflow: hidden; }
  /* The fill goes red to orange. transition:width makes it animate smoothly! */
  #hpFill { height: 100%; background: linear-gradient(90deg,#ff4444,#ff8800); transition: width 0.2s; border-radius: 2px; }

  #bossTimerVal { color: var(--gold); font-family: 'Press Start 2P', monospace; font-size: 11px; }
  #dayLabel { font-family: 'Press Start 2P', monospace; font-size: 10px; min-width: 80px; text-align:right; }
  #scoreVal { color: var(--gold); }   /* score shown in gold */
  #levelVal { color: #88ffff; }       /* level shown in cyan */
  .hud-label { color: #448844; font-size: 11px; } /* dim green labels like "HP", "LVL" */

  /* 
    CONTROLS BAR - the strip at the BOTTOM showing keyboard shortcuts.
    Same idea as the HUD but stuck to the bottom.
  */
  #controls {
    position: fixed; bottom: 0; left: 0; right: 0; /* glued to the bottom */
    background: var(--panel);
    border-top: 1px solid #1a4a1a;
    padding: 5px 12px;
    font-size: 11px; color: #448844;
    z-index: 900;
    display: flex; gap: 12px; flex-wrap: wrap; /* wrap to next line if too narrow */
    backdrop-filter: blur(4px);
  }
  #controls span { color: var(--green); }

  /* 
    TITLE SCREEN - The very first screen you see.
    It covers everything (inset:0 fills the whole window).
    justify-content:center puts everything in the middle.
  */
  #titleScreen {
    position: fixed; inset: 0; /* inset:0 = top:0 right:0 bottom:0 left:0 all at once */
    background: #000;
    display: flex; flex-direction: column; /* stack children vertically */
    justify-content: center; align-items: center; /* center everything */
    z-index: 2000; text-align: center; /* z-index 2000 = on top of the game */
    gap: 16px; /* space between each child element */
  }

  /* The ASCII art logo - tiny text characters arranged to make a picture! */
  #ascii {
    font-size: 9px; line-height: 13px;
    color: var(--green);
    text-shadow: 0 0 8px #88ff88, 0 0 20px #44aa44; /* green glow effect */
    letter-spacing: 0;
    animation: flicker 4s infinite; /* use the flicker animation defined below */
  }

  /* 
    @keyframes = describes an animation step by step.
    "flicker" makes the opacity (visibility) vary slightly,
    like an old TV screen or a neon sign flickering!
  */
  @keyframes flicker {
    0%,100%{opacity:1}   /* fully visible at start and end */
    92%{opacity:1}        /* still fully visible at 92%... */
    93%{opacity:0.85}     /* ...quick dip to slightly dim... */
    95%{opacity:1}        /* ...back to full... */
    97%{opacity:0.9}      /* ...another tiny dip */
  }

  /* "BOSS EDITION" title text in big gold letters */
  #titleText {
    font-family: 'Press Start 2P', monospace;
    font-size: 20px;
    color: var(--gold);
    text-shadow: 0 0 12px var(--gold); /* golden glow */
    letter-spacing: 2px;
  }

  #subtitleText { color: #448844; font-size: 13px; max-width: 560px; line-height: 1.6; }

  /* The green START GAME button */
  #startBtn {
    padding: 14px 40px;
    font-family: 'Press Start 2P', monospace;
    font-size: 14px;
    background: #000;
    color: var(--green);
    border: 2px solid var(--green);
    cursor: pointer;       /* shows a hand cursor when you hover */
    letter-spacing: 2px;
    box-shadow: 0 0 12px #44aa44;
    transition: all 0.15s; /* smooth change when hovering */
    animation: pulse 2s infinite; /* glow pulses like a heartbeat */
  }

  /* "pulse" makes the button glow brighter and dimmer like a heartbeat! */
  @keyframes pulse {
    0%,100%{box-shadow:0 0 12px #44aa44}              /* normal glow */
    50%{box-shadow:0 0 24px #88ff88,0 0 40px #44aa44} /* bigger glow at halfway */
  }

  /* When you hover: swap the colors (black bg becomes green bg) */
  #startBtn:hover { background: var(--green); color: #000; box-shadow: 0 0 30px #88ff88; }

  #keyHints { color: #336633; font-size: 12px; }

  /* 
    OVERLAYS - screens that appear ON TOP of everything.
    They start hidden (display:none) and JavaScript shows them when needed.
  */
  .overlay {
    position: fixed; inset: 0;
    display: none; flex-direction: column; /* hidden by default! */
    justify-content: center; align-items: center;
    z-index: 3000; text-align: center; gap: 16px; /* z-index 3000 = front of EVERYTHING */
    backdrop-filter: blur(6px); /* blurs the game behind it */
  }

  /* The red GAME OVER screen */
  #gameOverScreen { background: rgba(0,0,0,0.92); color: var(--red); }
  #gameOverScreen h1 { font-family: 'Press Start 2P', monospace; font-size: 28px; text-shadow: 0 0 20px var(--red); }
  #gameOverScreen .sub { color: #884444; font-size: 13px; }
  .overlay button {
    padding: 12px 32px;
    font-family: 'Press Start 2P', monospace; font-size: 13px;
    background: #000; cursor: pointer; border: 2px solid;
    letter-spacing: 1px; transition: all 0.15s;
  }
  #gameOverScreen button { color: var(--red); border-color: var(--red); }
  #gameOverScreen button:hover { background: var(--red); color: #000; }

  /* 
    TOAST NOTIFICATION - the floating pop-up like "LEVEL UP!" or "RAGE ACTIVATED!"
    Sits at the top-center and fades in/out using opacity.
    pointer-events:none means you can't accidentally click on it!
  */
  #levelUpToast {
    position: fixed; top: 60px; left: 50%; transform: translateX(-50%);
    font-family: 'Press Start 2P', monospace; font-size: 14px;
    color: var(--gold); text-shadow: 0 0 12px var(--gold);
    pointer-events: none; /* clicks pass right through it */
    z-index: 1000;
    opacity: 0; transition: opacity 0.3s; /* starts invisible, fades in smoothly */
  }

  /* 
    SCREEN SHAKE - when you get hit hard, the whole screen shakes!
    This animation moves things left-right and up-down rapidly.
    JavaScript adds the "shaking" class to trigger this, then removes it.
  */
  @keyframes shake {
    0%,100%{transform:translate(0,0)}    /* centered */
    20%{transform:translate(-4px,3px)}   /* left and slightly down */
    40%{transform:translate(4px,-3px)}   /* right and slightly up */
    60%{transform:translate(-3px,2px)}   /* left again */
    80%{transform:translate(3px,-2px)}   /* right again */
  }
  .shaking { animation: shake 0.25s; } /* the shake lasts a quarter of a second */

  /* 
    BOSS ALERT - the big scary "BOSS INCOMING" text in the middle of the screen.
    Starts invisible (opacity:0) and JavaScript fades it in when a boss is near!
  */
  #bossAlert {
    position: fixed; top: 50%; left: 50%; transform: translate(-50%,-50%);
    font-family: 'Press Start 2P', monospace; font-size: 22px;
    color: var(--red); text-shadow: 0 0 20px var(--red);
    pointer-events: none;
    z-index: 1500;
    opacity: 0; transition: opacity 0.4s; /* fades in and out */
    text-align: center;
  }
</style>
</head>
